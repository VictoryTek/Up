{
    "app-id": "io.github.up",
    "runtime": "org.gnome.Platform",
    "runtime-version": "46",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command": "up",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--talk-name=org.freedesktop.Flatpak",
        "--talk-name=org.freedesktop.PolicyKit1",
        "--filesystem=/etc/os-release:ro",
        "--filesystem=/etc/nixos:ro",
        "--filesystem=~/.nix-profile:ro",
        "--filesystem=/usr:ro"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin",
        "env": {
            "CARGO_HOME": "/run/build/up/cargo"
        }
    },
    "modules": [
        {
            "name": "up",
            "buildsystem": "meson",
            "config-opts": [
                "-Dbuildtype=release"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
            ]
        }
    ]
}
